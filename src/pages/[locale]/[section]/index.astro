---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import FlashcardList from '../../../components/FlashcardList.astro';
import { t, localePath, type Locale, locales } from '../../../i18n/utils';
import { getSectionMeta, getAllSectionSlugs } from '../../../i18n/sections';
import { getSectionColor, typeDotClasses, typeTextClasses, typeColors } from '../../../lib/colors';

export async function getStaticPaths() {
  const sectionSlugs = getAllSectionSlugs();

  return locales.flatMap(locale =>
    sectionSlugs.map(section => ({
      params: { locale, section },
    }))
  );
}

const { locale, section } = Astro.params as { locale: Locale; section: string };
const meta = getSectionMeta(section, locale);
const sectionColor = getSectionColor(section);

if (!meta) {
  return Astro.redirect(localePath(locale));
}

const allQuestions = await getCollection('questions');
const sectionQuestions = allQuestions
  .filter(q => q.data.section === section)
  .sort((a, b) => a.data.order - b.data.order);

const TYPE_ORDER = ['basic', 'deep', 'trick', 'practical'] as const;

const questionKey = `${locale}_question` as const;
const answerKey = `${locale}_answer` as const;

// Group questions by type
const grouped = TYPE_ORDER
  .map(type => ({
    type,
    questions: sectionQuestions
      .filter(q => (q.data.type || 'basic') === type)
      .map(q => {
        const slug = q.id.split('/').pop() || q.id;
        return {
          slug,
          question: (q.data as any)[questionKey] as string,
          answer: (q.data as any)[answerKey] as string,
          type: (q.data.type || 'basic') as 'basic' | 'deep' | 'trick' | 'practical',
          tags: q.data.tags || [],
        };
      }),
  }))
  .filter(g => g.questions.length > 0);

// Total count for header
const totalCount = sectionQuestions.length;

// Type counts for summary (only non-zero types)
const typeCounts = TYPE_ORDER
  .map(type => ({
    type,
    count: sectionQuestions.filter(q => (q.data.type || 'basic') === type).length,
  }))
  .filter(tc => tc.count > 0);

---
<BaseLayout
  title={`${meta.name} - ${t(locale, 'site.title')}`}
  description={meta.description}
  locale={locale}
>
  <Header locale={locale} currentPath={section} />
  <main data-pagefind-body data-section={section} class="mx-auto max-w-4xl px-4 py-8 sm:px-6 sm:py-12">
    <div class="mb-8" data-pagefind-ignore>
      <a href={localePath(locale)}
         class="inline-flex items-center gap-1 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 mb-4 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {t(locale, 'section.back')}
      </a>
      <div class="flex items-center gap-3">
        <div
          class="w-10 h-10 rounded-[10px] flex items-center justify-center shrink-0"
          style={`background: linear-gradient(135deg, ${sectionColor.gradientFrom}, ${sectionColor.gradientTo});`}
        >
          <span class="text-xl" role="img" aria-hidden="true">{meta.icon}</span>
        </div>
        <div>
          <h1 class="text-2xl font-extrabold text-gray-900 dark:text-gray-100 sm:text-3xl">{meta.name}</h1>
          <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">
            {totalCount} {t(locale, 'section.questions')}
          </p>
        </div>
      </div>
      {typeCounts.length > 1 && (
        <div class="flex flex-wrap items-center gap-3 mt-2 ml-12">
          {typeCounts.map(tc => (
              <span class={`inline-flex items-center gap-1 text-xs font-normal ${typeTextClasses[tc.type]}`}>
                <span class={`w-2 h-2 rounded-full ${typeDotClasses[tc.type]}`}></span>
                {tc.count} {t(locale, `group.${tc.type}` as any)}
              </span>
          ))}
          <button
            id="toggle-all-groups"
            class="ml-auto text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 underline transition-colors"
            data-collapse-label={t(locale, 'group.collapseAll')}
            data-expand-label={t(locale, 'group.expandAll')}
          >
            {t(locale, 'group.collapseAll')}
          </button>
        </div>
      )}
    </div>
    <div id="filter-bar" class="hidden mb-4 px-3 py-2 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl flex items-center justify-between text-sm" data-pagefind-ignore>
      <div class="flex items-center gap-2">
        <span class="text-base">🏷️</span>
        <span class="text-blue-800 dark:text-blue-300 font-medium">
          {t(locale, 'filter.activeLabel')}:
          <span id="filter-tag-name" class="font-semibold"></span>
        </span>
      </div>
      <button id="clear-filter" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 underline transition-colors">
        {t(locale, 'filter.showAll')}
      </button>
    </div>
    {grouped.map((group, index) => (
      grouped.length > 1 ? (
        <details open data-type-group={group.type} class:list={['group/typegroup', index === 0 ? '' : 'pt-8']}>
          <summary data-pagefind-ignore class="flex items-center gap-3 pb-3 border-b border-gray-200 dark:border-gray-700 cursor-pointer select-none list-none">
            <svg class:list={['w-5 h-5 transition-transform duration-200 group-open/typegroup:rotate-180 shrink-0', typeColors[group.type].chevron]}
                 viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd"
                    d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                    clip-rule="evenodd" />
            </svg>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">
              {t(locale, `group.${group.type}` as any)}
            </h2>
            <span class="text-sm text-gray-500 dark:text-gray-400">({group.questions.length})</span>
          </summary>
          <div class="mt-4">
            <FlashcardList questions={group.questions} locale={locale} />
          </div>
        </details>
      ) : (
        <div data-type-group={group.type}>
          <FlashcardList questions={group.questions} locale={locale} />
        </div>
      )
    ))}
  <script is:inline>
  (function() {
    var main = document.querySelector('main[data-section]');
    if (!main) return;
    var section = main.dataset.section;
    try {
      var collapsed = JSON.parse(localStorage.getItem('cheatsheet:collapsed:' + section) || '[]');
      if (!Array.isArray(collapsed)) return;
      collapsed.forEach(function(type) {
        if (!/^[a-z]+$/.test(type)) return;
        var el = main.querySelector('details[data-type-group="' + type + '"]');
        if (el) el.removeAttribute('open');
      });
    } catch (e) {}
  })();
</script>
  </main>

  <!-- Anchor link handler: opens and scrolls to linked question -->
  <script>
    function handleAnchorLink() {
      const hash = window.location.hash;
      if (!hash) return;

      const target = document.getElementById(hash.slice(1));
      if (!target) return;

      // Open ALL ancestor details elements (flashcard + type group)
      let el: HTMLElement | null = target.closest('details') || (target.tagName === 'DETAILS' ? target : null);
      while (el) {
        (el as HTMLDetailsElement).open = true;
        el = el.parentElement?.closest('details') as HTMLElement | null;
      }

      // Scroll to the innermost details (the flashcard)
      const scrollTarget = target.closest('details') || target;
      setTimeout(() => {
        scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });
        scrollTarget.classList.add('highlight');
        setTimeout(() => scrollTarget.classList.remove('highlight'), 2000);
      }, 100);
    }

    // Handle initial page load
    handleAnchorLink();

    // Handle hash changes (clicking anchor links on the same page)
    window.addEventListener('hashchange', handleAnchorLink);
  </script>

  <script>
    function initTagFilter() {
      const filterBar = document.getElementById('filter-bar');
      const filterTagName = document.getElementById('filter-tag-name');
      const clearBtn = document.getElementById('clear-filter');
      let activeTag: string | null = null;

      function applyFilter(tag: string | null) {
        activeTag = tag;

        // Update filter bar visibility
        if (filterBar) {
          filterBar.classList.toggle('hidden', !tag);
          // When visible, ensure flex display
          if (tag) filterBar.classList.add('flex');
          else filterBar.classList.remove('flex');
        }
        if (filterTagName && tag) {
          filterTagName.textContent = tag;
        }

        // Update tag badge active states
        document.querySelectorAll('.tag-filter').forEach(btn => {
          const btnTag = (btn as HTMLElement).dataset.tag;
          const isActive = btnTag === tag;
          btn.classList.toggle('ring-2', isActive);
          btn.classList.toggle('ring-blue-500', isActive);
          btn.classList.toggle('scale-110', isActive);
        });

        // Show/hide flashcards
        document.querySelectorAll('.flashcard').forEach(card => {
          if (!tag) {
            (card as HTMLElement).style.display = '';
            return;
          }
          const cardTags = (card as HTMLElement).dataset.tags?.split(',') || [];
          (card as HTMLElement).style.display = cardTags.includes(tag) ? '' : 'none';
        });

        // Show/hide empty type groups
        document.querySelectorAll('[data-type-group]').forEach(group => {
          if (!tag) {
            (group as HTMLElement).style.display = '';
            return;
          }
          const visibleCards = group.querySelectorAll('.flashcard:not([style*="display: none"])');
          (group as HTMLElement).style.display = visibleCards.length ? '' : 'none';
        });

        // Update collapse-all/expand-all button label after filter changes group visibility
        document.dispatchEvent(new CustomEvent('groups-visibility-changed'));
      }

      // Tag badge click handler (event delegation on main)
      document.querySelector('main')?.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.tag-filter');
        if (!btn) return;
        e.preventDefault();
        // Prevent details from toggling when clicking tag inside summary
        e.stopPropagation();
        const tag = (btn as HTMLElement).dataset.tag || null;
        applyFilter(tag === activeTag ? null : tag);
      });

      // Clear filter button
      clearBtn?.addEventListener('click', () => applyFilter(null));
    }

    initTagFilter();
  </script>

  <script>
  function initGroupToggle() {
    const toggleBtn = document.getElementById('toggle-all-groups');
    const main = document.querySelector<HTMLElement>('main[data-section]');
    if (!main) return;

    const section = main.dataset.section!;
    const storageKey = `cheatsheet:collapsed:${section}`;

    function getVisibleGroups(): HTMLDetailsElement[] {
      return Array.from(document.querySelectorAll<HTMLDetailsElement>('details[data-type-group]'))
        .filter(el => el.style.display !== 'none');
    }

    function saveState() {
      const all = document.querySelectorAll<HTMLDetailsElement>('details[data-type-group]');
      const collapsed = Array.from(all)
        .filter(el => !el.open)
        .map(el => el.dataset.typeGroup!);
      try {
        if (collapsed.length === 0) {
          localStorage.removeItem(storageKey);
        } else {
          localStorage.setItem(storageKey, JSON.stringify(collapsed));
        }
      } catch (e) {}
    }

    function updateButtonLabel() {
      if (!toggleBtn) return;
      const visible = getVisibleGroups();
      const anyOpen = visible.some(el => el.open);
      toggleBtn.textContent = anyOpen
        ? toggleBtn.dataset.collapseLabel!
        : toggleBtn.dataset.expandLabel!;
    }

    toggleBtn?.addEventListener('click', () => {
      const visible = getVisibleGroups();
      const anyOpen = visible.some(el => el.open);
      visible.forEach(el => el.open = !anyOpen);
      saveState();
      updateButtonLabel();
    });

    // Update label and persist when individual groups are toggled
    document.querySelectorAll('details[data-type-group]').forEach(el => {
      el.addEventListener('toggle', () => {
        saveState();
        updateButtonLabel();
      });
    });

    // Listen for visibility changes from tag filter
    document.addEventListener('groups-visibility-changed', updateButtonLabel);

    updateButtonLabel();
  }

  initGroupToggle();
  </script>
</BaseLayout>
