---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import FlashcardList from '../../../components/FlashcardList.astro';
import { t, localePath, type Locale, locales } from '../../../i18n/utils';
import { getSectionMeta, getAllSectionSlugs } from '../../../i18n/sections';

export async function getStaticPaths() {
  const sectionSlugs = getAllSectionSlugs();

  return locales.flatMap(locale =>
    sectionSlugs.map(section => ({
      params: { locale, section },
    }))
  );
}

const { locale, section } = Astro.params as { locale: Locale; section: string };
const meta = getSectionMeta(section, locale);

if (!meta) {
  return Astro.redirect(localePath(locale));
}

const allQuestions = await getCollection('questions');
const sectionQuestions = allQuestions
  .filter(q => q.data.section === section)
  .sort((a, b) => a.data.order - b.data.order);

const TYPE_ORDER = ['basic', 'deep', 'trick', 'practical'] as const;

const questionKey = `${locale}_question` as const;
const answerKey = `${locale}_answer` as const;

// Group questions by type
const grouped = TYPE_ORDER
  .map(type => ({
    type,
    questions: sectionQuestions
      .filter(q => (q.data.type || 'basic') === type)
      .map(q => {
        const slug = q.id.split('/').pop() || q.id;
        return {
          slug,
          question: (q.data as any)[questionKey] as string,
          answer: (q.data as any)[answerKey] as string,
          type: (q.data.type || 'basic') as 'basic' | 'deep' | 'trick' | 'practical',
        };
      }),
  }))
  .filter(g => g.questions.length > 0);

// Total count for header
const totalCount = sectionQuestions.length;

// Type counts for summary (only non-zero types)
const typeCounts = TYPE_ORDER
  .map(type => ({
    type,
    count: sectionQuestions.filter(q => (q.data.type || 'basic') === type).length,
  }))
  .filter(tc => tc.count > 0);

// Color maps for type count dots
const dotColors: Record<string, string> = {
  basic: 'bg-gray-400',
  deep: 'bg-blue-500',
  trick: 'bg-amber-500',
  practical: 'bg-green-500',
};
const textColors: Record<string, string> = {
  basic: 'text-gray-600 dark:text-gray-400',
  deep: 'text-blue-700 dark:text-blue-300',
  trick: 'text-amber-700 dark:text-amber-300',
  practical: 'text-green-700 dark:text-green-300',
};
---
<BaseLayout
  title={`${meta.name} - ${t(locale, 'site.title')}`}
  description={meta.description}
  locale={locale}
>
  <Header locale={locale} currentPath={section} />
  <main data-pagefind-body class="mx-auto max-w-4xl px-4 py-8 sm:px-6 sm:py-12">
    <div class="mb-8" data-pagefind-ignore>
      <a href={localePath(locale)}
         class="inline-flex items-center gap-1 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 mb-4 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {t(locale, 'section.back')}
      </a>
      <div class="flex items-center gap-3">
        <span class="text-3xl" role="img" aria-hidden="true">{meta.icon}</span>
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 sm:text-3xl">{meta.name}</h1>
          <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">
            {totalCount} {t(locale, 'section.questions')}
          </p>
        </div>
      </div>
      {typeCounts.length > 1 && (
        <div class="flex flex-wrap items-center gap-3 mt-2 ml-12">
          {typeCounts.map(tc => (
              <span class={`inline-flex items-center gap-1 text-xs font-normal ${textColors[tc.type]}`}>
                <span class={`w-2 h-2 rounded-full ${dotColors[tc.type]}`}></span>
                {tc.count} {t(locale, `group.${tc.type}` as any)}
              </span>
          ))}
        </div>
      )}
    </div>
    {grouped.map((group, index) => (
      <div>
        {grouped.length > 1 && (
          <div data-pagefind-ignore class:list={['flex items-center gap-3 pb-3 border-b border-gray-200 dark:border-gray-700', index === 0 ? 'pt-0' : 'pt-8']}>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">
              {t(locale, `group.${group.type}` as any)}
            </h2>
            <span class="text-sm text-gray-500 dark:text-gray-400">({group.questions.length})</span>
          </div>
        )}
        <div class={grouped.length > 1 ? 'mt-4' : ''}>
          <FlashcardList questions={group.questions} locale={locale} />
        </div>
      </div>
    ))}
  </main>

  <!-- Anchor link handler: opens and scrolls to linked question -->
  <script>
    function handleAnchorLink() {
      const hash = window.location.hash;
      if (!hash) return;

      const target = document.getElementById(hash.slice(1));
      if (!target) return;

      // Open the details element if it's a flashcard
      if (target.tagName === 'DETAILS') {
        (target as HTMLDetailsElement).open = true;
      }

      // Scroll to target with a short delay to allow details to open
      setTimeout(() => {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        target.classList.add('highlight');
        setTimeout(() => target.classList.remove('highlight'), 2000);
      }, 100);
    }

    // Handle initial page load
    handleAnchorLink();

    // Handle hash changes (clicking anchor links on the same page)
    window.addEventListener('hashchange', handleAnchorLink);
  </script>
</BaseLayout>
