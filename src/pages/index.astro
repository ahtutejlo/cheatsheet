---
// Root URL redirects to default locale (Ukrainian)
// Using meta refresh because Astro.redirect() has URL concatenation issues in static mode with base path
---
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${import.meta.env.BASE_URL.replace(/\/?$/, '/')}ua/`} />
    <title>Redirecting...</title>
  </head>
  <body></body>
</html>
