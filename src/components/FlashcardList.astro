---
import Flashcard from './Flashcard.astro';

interface QuestionData {
  slug: string;
  question: string;
  answer: string;
  type?: 'basic' | 'deep' | 'trick' | 'practical';
  tags?: string[];
}

interface Props {
  questions: QuestionData[];
  locale: 'ua' | 'en';
}

const { questions, locale } = Astro.props;
---
<div class="flex flex-col gap-3">
  {questions.map(q => (
    <Flashcard slug={q.slug} question={q.question} answer={q.answer} type={q.type} tags={q.tags} locale={locale} />
  ))}
</div>
